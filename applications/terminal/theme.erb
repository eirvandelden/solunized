<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>ANSIBlackColor</key>
	<data><%= hex_to_term_color(c(variant, "fg_0")) %></data>
	<key>ANSIRedColor</key>
	<data><%= hex_to_term_color(c(variant, "red")) %></data>
	<key>ANSIGreenColor</key>
	<data><%= hex_to_term_color(c(variant, "green")) %></data>
	<key>ANSIYellowColor</key>
	<data><%= hex_to_term_color(c(variant, "yellow")) %></data>
	<key>ANSIBlueColor</key>
	<data><%= hex_to_term_color(c(variant, "blue")) %></data>
	<key>ANSIMagentaColor</key>
	<data><%= hex_to_term_color(c(variant, "magenta")) %></data>
	<key>ANSICyanColor</key>
	<data><%= hex_to_term_color(c(variant, "cyan")) %></data>
	<key>ANSIWhiteColor</key>
	<data><%= hex_to_term_color(c(variant, "dim_0")) %></data>
	<key>ANSIBrightBlackColor</key>
	<data><%= hex_to_term_color(c(variant, "fg_1")) %></data>
	<key>ANSIBrightRedColor</key>
	<data><%= hex_to_term_color(c(variant, "br_red")) %></data>
	<key>ANSIBrightGreenColor</key>
	<data><%= hex_to_term_color(c(variant, "br_green")) %></data>
	<key>ANSIBrightYellowColor</key>
	<data><%= hex_to_term_color(c(variant, "br_yellow")) %></data>
	<key>ANSIBrightBlueColor</key>
	<data><%= hex_to_term_color(c(variant, "br_blue")) %></data>
	<key>ANSIBrightMagentaColor</key>
	<data><%= hex_to_term_color(c(variant, "br_magenta")) %></data>
	<key>ANSIBrightCyanColor</key>
	<data><%= hex_to_term_color(c(variant, "br_cyan")) %></data>
	<key>ANSIBrightWhiteColor</key>
	<data><%= hex_to_term_color(c(variant, "fg_1")) %></data>
	<key>BackgroundColor</key>
	<data><%= hex_to_term_color(c(variant, "bg_0")) %></data>
	<key>CursorColor</key>
	<data><%= hex_to_term_color(c(variant, "orange")) %></data>
	<key>ForegroundColor</key>
	<data><%= hex_to_term_color(c(variant, "fg_1")) %></data>
	<key>SelectionColor</key>
	<data><%= hex_to_term_color(c(variant, "bg_2")) %></data>
	<key>TextBoldColor</key>
	<data><%= hex_to_term_color(c(variant, "fg_1")) %></data>
	<key>name</key>
	<string><%= theme_data["display_name"] %></string>
	<key>type</key>
	<string>Window Settings</string>
</dict>
</plist>
