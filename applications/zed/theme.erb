{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Solunized",
  "author": "Solunized",
  "themes": [
<% themes.each_with_index do |(variant, theme_data), idx| -%>
    {
      "name": "<%= theme_data["display_name"] %>",
      "appearance": "<%= theme_data["interface_style"] %>",
      "style": {
        "background": "<%= c(variant, "bg_0") %>",
        "surface.background": "<%= c(variant, "bg_0") %>",
        "elevated_surface.background": "<%= c(variant, "bg_1") %>",
        "panel.background": "<%= c(variant, "bg_1") %>",
        "panel.focused_border": "<%= c(variant, "blue") %>",
        "title_bar.background": "<%= c(variant, "bg_1") %>",
        "title_bar.inactive_background": "<%= c(variant, "bg_1") %>",
        "toolbar.background": "<%= c(variant, "bg_0") %>",
        "tab_bar.background": "<%= c(variant, "bg_1") %>",
        "tab.active_background": "<%= c(variant, "bg_0") %>",
        "tab.inactive_background": "<%= c(variant, "bg_1") %>",
        "status_bar.background": "<%= c(variant, "bg_1") %>",
        "editor.background": "<%= c(variant, "bg_0") %>",
        "editor.gutter.background": "<%= c(variant, "bg_0") %>",
        "editor.subheader.background": "<%= c(variant, "bg_1") %>",
        "editor.active_line.background": "<%= c(variant, "bg_1") %>",
        "editor.highlighted_line.background": "<%= c(variant, "bg_1") %>",
        "editor.line_number": "<%= c(variant, "bg_2") %>",
        "editor.active_line_number": "<%= c(variant, "dim_0") %>",
        "editor.invisible": "<%= c(variant, "bg_2") %>",
        "editor.wrap_guide": "<%= c(variant, "bg_1") %>",
        "editor.active_wrap_guide": "<%= c(variant, "bg_2") %>",
        "editor.document_highlight.read_background": "<%= c(variant, "bg_2") %>",
        "editor.document_highlight.write_background": "<%= c(variant, "bg_2") %>",
        "text": "<%= c(variant, "fg_1") %>",
        "text.muted": "<%= c(variant, "fg_0") %>",
        "text.placeholder": "<%= c(variant, "dim_0") %>",
        "text.disabled": "<%= c(variant, "dim_0") %>",
        "text.accent": "<%= c(variant, "blue") %>",
        "icon": "<%= c(variant, "fg_0") %>",
        "icon.muted": "<%= c(variant, "dim_0") %>",
        "icon.disabled": "<%= c(variant, "bg_2") %>",
        "icon.placeholder": "<%= c(variant, "dim_0") %>",
        "icon.accent": "<%= c(variant, "blue") %>",
        "border": "<%= c(variant, "bg_2") %>",
        "border.variant": "<%= c(variant, "bg_2") %>",
        "border.focused": "<%= c(variant, "blue") %>",
        "border.selected": "<%= c(variant, "blue") %>",
        "border.transparent": null,
        "border.disabled": "<%= c(variant, "bg_2") %>",
        "drop_target.background": "<%= c(variant, "bg_2") %>",
        "ghost_element.background": null,
        "ghost_element.hover": "<%= c(variant, "bg_1") %>",
        "ghost_element.active": "<%= c(variant, "bg_2") %>",
        "ghost_element.selected": "<%= c(variant, "bg_1") %>",
        "ghost_element.disabled": null,
        "element.background": "<%= c(variant, "bg_1") %>",
        "element.hover": "<%= c(variant, "bg_2") %>",
        "element.active": "<%= c(variant, "bg_2") %>",
        "element.selected": "<%= c(variant, "bg_1") %>",
        "element.disabled": "<%= c(variant, "bg_1") %>",
        "element.placeholder": "<%= c(variant, "dim_0") %>",
        "element.error": "<%= c(variant, "br_red") %>",
        "element.warning": "<%= c(variant, "orange") %>",
        "element.success": "<%= c(variant, "green") %>",
        "element.info": "<%= c(variant, "blue") %>",
        "scrollbar.thumb.background": "<%= c(variant, "bg_2") %>",
        "scrollbar.thumb.hover_background": "<%= c(variant, "dim_0") %>",
        "scrollbar.thumb.border": "<%= c(variant, "bg_2") %>",
        "scrollbar.track.background": "<%= c(variant, "bg_1") %>",
        "scrollbar.track.border": "<%= c(variant, "bg_1") %>",
        "search.match_background": "<%= c(variant, "yellow") %>",
        "conflict": "<%= c(variant, "orange") %>",
        "conflict.background": "<%= c(variant, "bg_1") %>",
        "conflict.border": "<%= c(variant, "orange") %>",
        "created": "<%= c(variant, "br_green") %>",
        "created.background": "<%= c(variant, "bg_1") %>",
        "created.border": "<%= c(variant, "br_green") %>",
        "deleted": "<%= c(variant, "red") %>",
        "deleted.background": "<%= c(variant, "bg_1") %>",
        "deleted.border": "<%= c(variant, "red") %>",
        "modified": "<%= c(variant, "br_yellow") %>",
        "modified.background": "<%= c(variant, "bg_1") %>",
        "modified.border": "<%= c(variant, "br_yellow") %>",
        "error": "<%= c(variant, "br_red") %>",
        "error.background": "<%= c(variant, "bg_1") %>",
        "error.border": "<%= c(variant, "br_red") %>",
        "warning": "<%= c(variant, "orange") %>",
        "warning.background": "<%= c(variant, "bg_1") %>",
        "warning.border": "<%= c(variant, "orange") %>",
        "success": "<%= c(variant, "green") %>",
        "success.background": "<%= c(variant, "bg_1") %>",
        "success.border": "<%= c(variant, "green") %>",
        "info": "<%= c(variant, "blue") %>",
        "info.background": "<%= c(variant, "bg_1") %>",
        "info.border": "<%= c(variant, "blue") %>",
        "hidden": "<%= c(variant, "dim_0") %>",
        "hidden.background": "<%= c(variant, "bg_1") %>",
        "hidden.border": "<%= c(variant, "dim_0") %>",
        "predictive": "<%= c(variant, "dim_0") %>",
        "renamed": "<%= c(variant, "blue") %>",
        "renamed.background": "<%= c(variant, "bg_1") %>",
        "renamed.border": "<%= c(variant, "blue") %>",
        "hint": "<%= c(variant, "cyan") %>",
        "hint.background": "<%= c(variant, "bg_1") %>",
        "hint.border": "<%= c(variant, "cyan") %>",
        "terminal.background": "<%= c(variant, "bg_0") %>",
        "terminal.foreground": "<%= c(variant, "fg_1") %>",
        "terminal.bright_foreground": "<%= c(variant, "fg_1") %>",
        "terminal.dim_foreground": "<%= c(variant, "fg_0") %>",
        "terminal.ansi.black": "<%= c(variant, "fg_0") %>",
        "terminal.ansi.red": "<%= c(variant, "red") %>",
        "terminal.ansi.green": "<%= c(variant, "green") %>",
        "terminal.ansi.yellow": "<%= c(variant, "yellow") %>",
        "terminal.ansi.blue": "<%= c(variant, "blue") %>",
        "terminal.ansi.magenta": "<%= c(variant, "magenta") %>",
        "terminal.ansi.cyan": "<%= c(variant, "cyan") %>",
        "terminal.ansi.white": "<%= c(variant, "dim_0") %>",
        "terminal.ansi.bright_black": "<%= c(variant, "fg_1") %>",
        "terminal.ansi.bright_red": "<%= c(variant, "br_red") %>",
        "terminal.ansi.bright_green": "<%= c(variant, "br_green") %>",
        "terminal.ansi.bright_yellow": "<%= c(variant, "br_yellow") %>",
        "terminal.ansi.bright_blue": "<%= c(variant, "br_blue") %>",
        "terminal.ansi.bright_magenta": "<%= c(variant, "br_magenta") %>",
        "terminal.ansi.bright_cyan": "<%= c(variant, "br_cyan") %>",
        "terminal.ansi.bright_white": "<%= c(variant, "fg_1") %>",
        "players": [
          {
            "cursor": "<%= c(variant, "blue") %>",
            "background": "<%= c(variant, "blue") %>",
            "selection": "<%= c(variant, "bg_2") %>"
          }
        ],
        "syntax": {
          "attribute": { "color": "<%= c(variant, "green") %>" },
          "boolean": { "color": "<%= c(variant, "cyan") %>" },
          "comment": { "color": "<%= c(variant, "dim_0") %>", "font_style": "italic" },
          "comment.doc": { "color": "<%= c(variant, "dim_0") %>", "font_style": "italic" },
          "constant": { "color": "<%= c(variant, "cyan") %>" },
          "constructor": { "color": "<%= c(variant, "blue") %>" },
          "emphasis": { "color": "<%= c(variant, "fg_1") %>", "font_style": "italic" },
          "emphasis.strong": { "color": "<%= c(variant, "fg_1") %>", "font_weight": 700 },
          "enum": { "color": "<%= c(variant, "green") %>" },
          "function": { "color": "<%= c(variant, "blue") %>" },
          "function.method": { "color": "<%= c(variant, "br_blue") %>" },
          "function.method.builtin": { "color": "<%= c(variant, "br_blue") %>" },
          "hint": { "color": "<%= c(variant, "cyan") %>", "font_style": "italic" },
          "keyword": { "color": "<%= c(variant, "dim_0") %>", "font_style": "italic", "font_weight": 700 },
          "label": { "color": "<%= c(variant, "green") %>" },
          "link_text": { "color": "<%= c(variant, "blue") %>", "font_style": "italic" },
          "link_uri": { "color": "<%= c(variant, "cyan") %>" },
          "number": { "color": "<%= c(variant, "cyan") %>" },
          "operator": { "color": "<%= c(variant, "dim_0") %>" },
          "predictive": { "color": "<%= c(variant, "dim_0") %>", "font_style": "italic" },
          "preproc": { "color": "<%= c(variant, "orange") %>" },
          "primary": { "color": "<%= c(variant, "fg_1") %>" },
          "property": { "color": "<%= c(variant, "green") %>" },
          "punctuation": { "color": "<%= c(variant, "dim_0") %>" },
          "punctuation.bracket": { "color": "<%= c(variant, "dim_0") %>" },
          "punctuation.delimiter": { "color": "<%= c(variant, "dim_0") %>" },
          "punctuation.list_marker": { "color": "<%= c(variant, "red") %>" },
          "punctuation.special": { "color": "<%= c(variant, "orange") %>" },
          "string": { "color": "<%= c(variant, "cyan") %>" },
          "string.escape": { "color": "<%= c(variant, "orange") %>" },
          "string.regex": { "color": "<%= c(variant, "red") %>" },
          "string.special": { "color": "<%= c(variant, "orange") %>" },
          "string.special.symbol": { "color": "<%= c(variant, "green") %>" },
          "tag": { "color": "<%= c(variant, "dim_0") %>" },
          "text.literal": { "color": "<%= c(variant, "cyan") %>" },
          "title": { "color": "<%= c(variant, "blue") %>", "font_weight": 700 },
          "type": { "color": "<%= c(variant, "orange") %>" },
          "type.builtin": { "color": "<%= c(variant, "orange") %>", "font_style": "italic" },
          "type.interface": { "color": "<%= c(variant, "orange") %>" },
          "type.super": { "color": "<%= c(variant, "orange") %>" },
          "variable": { "color": "<%= c(variant, "green") %>" },
          "variable.member": { "color": "<%= c(variant, "green") %>" },
          "variable.special": { "color": "<%= c(variant, "magenta") %>" },
          "variant": { "color": "<%= c(variant, "green") %>" }
        }
      }
    }<%= idx < themes.size - 1 ? "," : "" %>
<% end -%>
  ]
}
