-- Solunized colorscheme for Neovim
-- Auto-generated by generate_themes.rb — do not edit by hand.
-- https://github.com/solunized

local palettes = {
<% themes.each do |variant, theme_data| -%>
  ["<%= variant %>"] = {
<% theme_data["colors"].each do |name, hex| -%>
    <%= name.ljust(12) %> = "<%= hex %>",
<% end -%>
  },
<% end -%>
}

local function get_variant()
  if vim.o.background == "dark" then
    if vim.g.solunized_dark_variant == "black" then return "black" end
    return "dark"
  else
    if vim.g.solunized_light_variant == "white" then return "white" end
    return "light"
  end
end

local p = palettes[get_variant()]

vim.cmd("highlight clear")
if vim.fn.exists("syntax_on") == 1 then vim.cmd("syntax reset") end
vim.g.colors_name = "solunized"

local function hi(group, opts)
  vim.api.nvim_set_hl(0, group, opts)
end

